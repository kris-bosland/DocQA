@page "/about"
@inject IConfiguration Config
@inject ApiClient ApiClient

<PageTitle>DocQA — About</PageTitle>

<h1 class="h3 mb-4">About DocQA</h1>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <h5 class="card-title">Build Information</h5>
        <dl class="row mb-0">
            <dt class="col-sm-4">Client Build</dt>
            <dd class="col-sm-8">
                <code>@_clientBuildVersion</code>
            </dd>

            <dt class="col-sm-4">API Base URL</dt>
            <dd class="col-sm-8">
                <code>@_apiBaseUrl</code>
            </dd>

            <dt class="col-sm-4">Server Build</dt>
            <dd class="col-sm-8">
                <code>@_serverBuildVersion</code>
            </dd>

            <dt class="col-sm-4">Anthropic Model</dt>
            <dd class="col-sm-8">
                <code>@_anthropicModel</code>
            </dd>
        </dl>

        @if (_serverInfoError is not null)
        {
            <div class="alert alert-warning mt-3 mb-0">@_serverInfoError</div>
        }
    </div>
</div>

@code {
    private string _clientBuildVersion = "unknown";
    private string _apiBaseUrl = "unknown";
    private string _serverBuildVersion = "unknown";
    private string _anthropicModel = "unknown";
    private string? _serverInfoError;

    protected override async Task OnInitializedAsync()
    {
        _clientBuildVersion = Config["BuildVersion"] ?? "not configured";
        _apiBaseUrl = Config["ApiBaseUrl"] ?? "not configured";

        try
        {
            var info = await ApiClient.GetSystemInfoAsync();
            _serverBuildVersion = info.ServerBuildVersion;
            _anthropicModel = info.AnthropicModel;
        }
        catch (Exception ex)
        {
            _serverInfoError = $"Could not load server info from API: {ex.Message}";
        }
    }
}
